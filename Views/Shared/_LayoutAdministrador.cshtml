<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Administrador</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: #f8fafc;
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }

        .sidebar {
            width: 260px;
            background: white;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            flex-shrink: 0;
        }

        .nav-btn {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #475569;
            text-decoration: none;
            transition: all 0.3s;
            border-left: 4px solid transparent;
        }

            .nav-btn:hover, .nav-btn.active {
                background: #f1f5f9;
                border-left-color: #20c997;
                color: #20c997;
            }

        .main-content {
            flex-grow: 1;
            padding: 30px;
            overflow-y: auto;
        }

        .user-profile {
            background: #f8fafc;
            padding: 15px;
            border-radius: 8px;
            margin: 20px;
        }
    </style>
</head>
<body>

    <div class="sidebar shadow-sm">
        <div class="px-4 py-3 border-bottom">
            <h5 class="fw-bold text-success m-0">Admin Panel</h5>
        </div>

        <nav class="d-flex flex-column mt-3">
            <a href="@Url.Action("Index", "Administrador")" class="nav-btn @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">
                <i class="bi bi-house-door me-3"></i>Gestión de semillero
            </a>
            <a href="@Url.Action("Usuarios", "Administrador")" class="nav-btn @(ViewContext.RouteData.Values["action"].ToString() == "Usuarios" ? "active" : "")">
                <i class="bi bi-person-gear me-3"></i>Gestión de usuario
            </a>

            <a href="@Url.Action("RegistrarProyecto", "Administrador")" class="nav-btn @(ViewContext.RouteData.Values["action"].ToString() == "RegistrarProyecto" ? "active" : "")">
                <i class="bi bi-folder2-open me-3"></i>Proyectos
            </a>

            <a href="@Url.Action("RegistrarEvento", "Administrador")" class="nav-btn @(ViewContext.RouteData.Values["action"].ToString() == "RegistrarEvento" ? "active" : "")">
                <i class="bi bi-calendar-event me-3"></i>Eventos
            </a>

            <!-- ENLACE CORREGIDO Y ENRUTADO CON ACTIVACIÓN VISUAL PARA REPORTES -->
            <a href="@Url.Action("Reportes", "Administrador")" class="nav-btn @(ViewContext.RouteData.Values["action"].ToString() == "Reportes" ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph me-3"></i>Reportes
            </a>

            <a href="@Url.Action("Reuniones", "Administrador")" class="nav-btn @(ViewContext.RouteData.Values["action"].ToString() == "Reuniones" ? "active" : "")">
                <i class="bi bi-camera-video me-3"></i>Reuniones
            </a>
        </nav>

        <div class="user-profile mt-auto">
            <div class="d-flex align-items-center">
                <i class="bi bi-person-circle fs-3 me-2 text-secondary"></i>
                <div class="lh-1" style="overflow: hidden;">
                    <small class="fw-bold d-block text-truncate">
                        @if (Session["UsuarioLogueado"] != null)
                        {
                            var userObj = Session["UsuarioLogueado"] as GestionSemillero1.Models.Usuario;
                            @(userObj != null ? userObj.correo_usuario : Session["UsuarioLogueado"].ToString())
                        }
                        else
                        {
                            <span>admin@sena.edu.co</span>
                        }
                    </small>
                    <small class="text-success" style="font-size: 0.75em;">Rol Administrador</small>
                </div>
            </div>
            <a href="@Url.Action("Logout", "Account")" class="btn btn-sm btn-outline-danger mt-3 w-100">
                <i class="bi bi-box-arrow-left me-2"></i>Cerrar sesión
            </a>
        </div>
    </div>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
    @Html.Partial("_AsistenteChat")
</body>
</html>