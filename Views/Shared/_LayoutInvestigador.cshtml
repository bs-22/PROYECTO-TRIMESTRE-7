<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Dashboard Investigador</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Content/dashboard.css" rel="stylesheet" />
    <style>
        /* Base del sistema */
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            background: #f8fafc !important;
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
        }

        /* Contenedor Maestro */
        .dashboard-container {
            display: flex;
            width: 100%;
            min-height: 100vh;
            align-items: stretch;
            background: #f8fafc !important;
        }

        /* 🌟 SECCIÓN MODIFICADA: Ancho aumentado a 290px para que quepa todo el correo perfectamente */
        .sidebar {
            width: 290px;
            background-color: #ffffff !important;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            flex-shrink: 0;
            z-index: 100;
        }

        .sidebar-header {
            color: #198754;
            font-size: 1.15rem;
            font-weight: 700;
        }

        /* 🌟 TARJETA DE PERFIL INTERNA: Espaciado exacto como en tu captura */
        .profile-card {
            background-color: #f8f9fa !important;
            border-radius: 12px;
            padding: 16px;
            margin: 15px;
        }

        .profile-avatar {
            color: #64748b;
        }

        .profile-info h6 {
            color: #212529 !important;
            font-size: 15px;
            margin-bottom: 2px;
            white-space: nowrap; /* Evita que el correo se parta en dos líneas */
        }

        .profile-info small {
            color: #20c997 !important;
            font-weight: 600;
            font-size: 0.85rem;
        }

        /* Botones de Navegación */
        .sidebar .nav-link {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #475569 !important;
            text-decoration: none !important;
            transition: all 0.3s;
            border-left: 4px solid transparent;
            font-weight: 500;
            font-size: 15px;
        }

            .sidebar .nav-link i {
                font-size: 1.1rem;
                margin-right: 12px;
                color: #64748b;
            }

            /* Estado Activo / Hover */
            .sidebar .nav-link:hover, .sidebar .nav-link.active {
                background: #f1f5f9;
                border-left-color: #20c997;
                color: #20c997 !important;
            }

                .sidebar .nav-link:hover i, .sidebar .nav-link.active i {
                    color: #20c997 !important;
                }

        .logout-container {
            margin-top: auto; /* Empuja el bloque al fondo de la barra lateral */
        }

        /* 🌟 BOTÓN CERRAR SESIÓN OUTLINE ROJO */
        .btn-logout-outline {
            display: flex;
            align-items: center;
            justify-content: center;
            color: #dc3545 !important;
            border: 1px solid #dc3545;
            background-color: #ffffff;
            border-radius: 8px;
            padding: 10px 15px;
            text-decoration: none !important;
            font-weight: 500;
            font-size: 14px;
            transition: all 0.2s ease;
            width: 100%;
        }

            .btn-logout-outline:hover {
                background-color: #dc3545;
                color: #ffffff !important;
            }

        /* 🌟 CONTENIDO PRINCIPAL: Ajustado proporcionalmente al nuevo ancho de la barra */
        .main-content {
            flex-grow: 1;
            width: calc(100% - 290px);
            margin-left: 0 !important;
            padding: 30px;
            overflow-y: auto;
            box-sizing: border-box;
            background-color: #f8fafc !important;
        }

            .main-content .container,
            .main-content .container-fluid {
                max-width: 100% !important;
                width: 100% !important;
                padding: 0 !important;
            }
    </style>
</head>
<body>

    <div class="dashboard-container">

        <div class="sidebar shadow-sm">
            <div class="px-4 py-3 border-bottom">
                <h5 class="sidebar-header m-0">Investigador</h5>
            </div>

            <nav class="d-flex flex-column mt-3">
                <a class="nav-link active" href="@Url.Action("Index", "Investigador")">
                    <i class="bi bi-camera-video"></i> <span>Consultar Reuniones</span>
                </a>
            </nav>

            <div class="logout-container">
                <div class="profile-card mb-3">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="profile-avatar">
                            <i class="bi bi-person-circle fs-2 text-secondary"></i>
                        </div>
                        <div class="profile-info">
                            <h6 class="mb-0 fw-bold">@Session["UsuarioLogueado"]</h6>
                            <small>Rol Investigador</small>
                        </div>
                    </div>

                    <a class="btn-logout-outline" href="@Url.Action("Logout", "Account")">
                        <i class="bi bi-box-arrow-left me-2"></i> Cerrar sesión
                    </a>
                </div>
            </div>
        </div>

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>