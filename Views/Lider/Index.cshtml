@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Líder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Content/dashboard.css" rel="stylesheet" />
</head>
<body>

    <div class="sidebar">
        <div>
            <div class="profile-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="profile-avatar">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">@Session["UsuarioLogueado"]</h6>
                        <small class="opacity-75">Rol Líder</small>
                    </div>
                </div>
            </div>
            <nav class="d-flex flex-column mt-3">
                <a class="nav-link" href="#"><i class="bi bi-chat-square-text"></i> Consultar Reuniones</a>
                <a class="nav-link active" href="#"><i class="bi bi-calendar-plus"></i> Programar Reunion</a>
            </nav>
        </div>

        <div class="logout-container">
            <a class="btn-logout" href="@Url.Action("Logout", "Account")">
                <i class="bi bi-box-arrow-left"></i> Salir
            </a>
        </div>
    </div>

    <div class="main-content">
        <form action="#" method="POST">
            <div class="row">

                <div class="col-md-4 mb-4">
                    <div class="dashboard-card">
                        <h5 class="card-title"><span class="step-badge">1</span> Seleccione una fecha:</h5>
                        <input type="date" class="form-control-custom" required />
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="dashboard-card">
                        <h5 class="card-title"><span class="step-badge">2</span> Escriba el lugar donde se realizará:</h5>
                        <input type="text" class="form-control-custom" placeholder="Ingrese salón o enlace virtual" required />
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="dashboard-card">
                        <h5 class="card-title"><span class="step-badge">5</span> Seleccione hora de inicio:</h5>
                        <input type="time" class="form-control-custom" required />
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="dashboard-card">
                        <h5 class="card-title"><span class="step-badge">3</span> Seleccione los participantes:</h5>
                        <div class="participant-scrollbox">
                            <div class="checkbox-item"><input type="checkbox" id="p1"><label for="p1">Bryam De Jesús</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p2"><label for="p2">Samuel Alejandro</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p3"><label for="p3">Daniel Eduardo</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p4"><label for="p4">Jeremias De Jesus</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p5"><label for="p5">Roberto</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p6"><label for="p6">Devian Alexander</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p7"><label for="p7">Maikol Yesid</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p8"><label for="p8">Kerin antonio</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p9"><label for="p9">Keiler David</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p10"><label for="p10">Isacc Daniel</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p11"><label for="p11">Eduar Luis</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p12"><label for="p12">Leizmy</label></div>
                            <div class="checkbox-item"><input type="checkbox" id="p13"><label for="p13">Andres Felipe</label></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="dashboard-card">
                        <h5 class="card-title"><span class="step-badge">4</span> Asunto:</h5>
                        <textarea class="form-control-custom" rows="5" placeholder="Escriba el asunto detallado..." required></textarea>
                    </div>
                </div>

                <div class="col-md-4 mb-4 d-flex flex-column justify-content-between">
                    <div class="dashboard-card d-flex flex-column justify-content-between w-100 m-0">
                        <div>
                            <h5 class="card-title"><span class="step-badge">6</span> Seleccione hora de finalizacion:</h5>
                            <input type="time" class="form-control-custom" required />
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn-submit-gradient">
                                <i class="bi bi-pencil-square"></i> Registrar Reunión
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </form>
    </div>

</body>
</html>