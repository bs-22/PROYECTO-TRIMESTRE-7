@model List<GestionSemillero1.Models.investigadores>
@{
    ViewBag.Title = "Asignar Nueva Reunión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <h2>Gestionar Reuniones</h2>
    @using (Html.BeginForm("AsignarReunion", "Lider", FormMethod.Post))
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card p-4 shadow-sm mb-4">
                    <h4><i class="bi bi-info-circle"></i> Datos de la Reunión</h4>
                    <hr />
                    <div class="mb-3">
                        <label>Descripción / Objetivo:</label>
                        <input type="text" name="descripcion_reunion" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label>Hora Inicio:</label>
                            <input type="text" name="hora_reunion" class="form-control" placeholder="09:00 AM" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label>Hora Fin:</label>
                            <input type="text" name="hora_fin_reunion" class="form-control" placeholder="10:00 AM" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Lugar / Enlace:</label>
                        <input type="text" name="lugar_reunion" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Fecha:</label>
                        <input type="date" name="fecha_reunion" class="form-control" required />
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-4 shadow-sm">
                    <h4><i class="bi bi-people"></i> Seleccionar Participantes</h4>
                    <hr />
                    <div style="max-height: 350px; overflow-y: auto;">
                        <table class="table table-hover">
                            @foreach (var inv in Model)
                            {
                                <tr>
                                    <td><input type="checkbox" name="investigadoresSeleccionados" value="@inv.ID_investigador" /></td>
                                    <td>@inv.nombre_investigador @inv.apellido_investigador</td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success w-100 btn-lg">Registrar Reunión</button>
                </div>
            </div>
        </div>
    }
</div>