@model IEnumerable<GestionSemillero1.Models.semillero>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Gestionar Semillero";
    string seccionActiva = ViewBag.SeccionActual;
    decimal idSemilleroSeleccionadoSeccion4 = ViewBag.IdSemilleroSeleccionado4 ?? 0;
}

<div class="container-fluid">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="border-radius: 8px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- SECCIÓN DE BÚSQUEDA GENERAL (IZQUIERDA) -->
        <div class="col-xl-3 col-lg-4 mb-4">
            <div class="dashboard-card shadow-sm">
                <h5 class="card-title text-primary mb-3">
                    <i class="bi bi-funnel-fill text-primary me-2"></i>Búsqueda General
                </h5>

                @using (Html.BeginForm("GestionarSemillero", "Lider", FormMethod.Get))
                {
                    <input type="hidden" name="seccionCargada" value="filtros" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Filtrar por Semillero</label>
                        <select name="semilleroFiltro" class="form-control-custom">
                            <option value="">Todos los semilleros...</option>
                            @if (ViewBag.SemillerosFiltro != null)
                            {
                                foreach (var s in ViewBag.SemillerosFiltro as List<GestionSemillero1.Models.semillero>)
                                {
                                    <option value="@s.ID_semillero">@s.nombre_semillero</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Línea de Investigación</label>
                        <select name="lineaFiltro" class="form-control-custom">
                            <option value="">Todas las líneas...</option>
                            @if (ViewBag.LineasFiltro != null)
                            {
                                foreach (var linea in ViewBag.LineasFiltro as List<string>)
                                {
                                    <option value="@linea">@linea</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Fecha de Creación</label>
                        <input type="date" name="fechaFiltro" class="form-control-custom" value="2026-06-06" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary fw-bold" style="border-radius: 8px;">
                            <i class="bi bi-search me-2"></i>Aplicar Filtros
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- SECCIÓN PRINCIPAL DE CONTENIDOS (DERECHA) -->
        <div class="col-xl-9 col-lg-8">

            <ul class="nav nav-tabs border-0 mb-4 bg-white p-2 shadow-sm" style="border-radius: 12px; gap: 10px;">
                <li class="nav-item">
                    <button class="nav-link border-0 fw-bold px-4 py-2 @(seccionActiva != "investigadores" && seccionActiva != "filtros" ? "active text-success bg-light" : "text-muted bg-transparent")"
                            id="btn-tab-semilleros" onclick="cambiarVistaPestaña('semilleros')" style="border-radius: 8px; transition: all 0.2s;">
                        <i class="bi bi-building me-2"></i>Gestión de Semilleros
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link border-0 fw-bold px-4 py-2 @(seccionActiva == "investigadores" ? "active text-success bg-light" : "text-muted bg-transparent")"
                            id="btn-tab-investigadores" onclick="cambiarVistaPestaña('investigadores')" style="border-radius: 8px; transition: all 0.2s;">
                        <i class="bi bi-people-fill me-2"></i>Gestión de Investigadores
                    </button>
                </li>
                @if (seccionActiva == "filtros")
                {
                    <li class="nav-item ms-auto">
                        <span class="badge bg-primary-light text-primary p-2 fw-bold" style="border-radius: 8px;">
                            <i class="bi bi-funnel me-1"></i> Viendo Resultados Filtrados
                        </span>
                    </li>
                }
            </ul>

            <div class="tab-content">

                <!-- PESTAÑA: GESTIÓN DE SEMILLEROS -->
                <div class="tab-pane fade @(seccionActiva != "investigadores" && seccionActiva != "filtros" ? "show active" : "")">

                    @using (Html.BeginForm("GestionarSemillero", "Lider", FormMethod.Post, new { id = "formSemillero" }))
                    {
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <div class="dashboard-card h-100 shadow-sm">
                                    <h5 class="card-title mb-3"><span class="step-badge">1</span> Identificación</h5>
                                    <div class="mb-3">
                                        <input type="text" id="txtID" name="ID_semillero" class="form-control-custom" value="@ViewBag.SiguienteID" readonly style="background-color: #f8f9fa; cursor: not-allowed;" required />
                                    </div>
                                    <div>
                                        <input type="text" id="txtNombre" name="nombre_semillero" class="form-control-custom" placeholder="Nombre del semillero" required />
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <div class="dashboard-card h-100 shadow-sm">
                                    <h5 class="card-title mb-3"><span class="step-badge">2</span> Clasificación</h5>
                                    <div class="mb-3">
                                        <input type="text" id="txtLinea" name="linea_investigacion" class="form-control-custom" placeholder="Línea de investigación" required />
                                    </div>
                                    <div>
                                        <input type="date" id="txtFecha" name="fecha_creacion_semillero" class="form-control-custom" required />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="dashboard-card mb-4 shadow-sm">
                            <h5 class="card-title mb-3"><span class="step-badge">3</span> Descripción General</h5>
                            <textarea id="txtDescripcion" name="descripcion_semillero" class="form-control-custom" rows="3" placeholder="Escriba la descripción del semillero..."></textarea>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <button type="submit" name="accion" value="agregar" class="btn btn-success px-4" style="border-radius: 8px;"><i class="bi bi-plus-circle me-2"></i>Agregar</button>
                            <button type="submit" name="accion" value="actualizar" class="btn btn-warning px-4 text-white" style="border-radius: 8px;"><i class="bi bi-arrow-clockwise me-2"></i>Actualizar</button>
                            <button type="submit" name="accion" value="eliminar" class="btn btn-danger px-4" style="border-radius: 8px;"><i class="bi bi-trash me-2"></i>Eliminar</button>
                            <button type="button" id="btnLimpiar" class="btn btn-secondary px-4" style="border-radius: 8px;"><i class="bi bi-eraser me-2"></i>Limpiar</button>
                        </div>
                    }

                    <!-- FIX IMPORTANTE: La tabla de visualización ahora está fuera del Formulario para evitar falsos Submits -->
                    <div class="dashboard-card shadow-sm">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="card-title m-0"><i class="bi bi-table text-success me-2"></i>Semilleros del Sistema</h5>
                            <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Haga clic en una fila para editar sus datos arriba</small>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="tablaSemilleros" style="cursor: pointer;">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre</th>
                                        <th>Fecha Creación</th>
                                        <th>Línea de Investigación</th>
                                        <th>Estado</th>
                                        <th style="display:none;">Descripción Oculta</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold ID-celda">@item.ID_semillero</td>
                                            <td>@item.nombre_semillero</td>
                                            <td>@(item.fecha_creacion_semillero != null ? item.fecha_creacion_semillero.ToString("yyyy-MM-dd") : "")</td>
                                            <td>@item.linea_investigacion</td>
                                            <td><span class="badge bg-success text-white p-2" style="border-radius:6px;">@item.estado</span></td>
                                            <td style="display:none;" class="descripcion-oculta">@item.descripcion_semillero</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>

                <!-- PESTAÑA: GESTIÓN DE INVESTIGADORES -->
                <div class="tab-pane fade @(seccionActiva == "investigadores" ? "show active" : "")">
                    <div class="row">
                        <div class="col-lg-4 mb-4">
                            <div class="dashboard-card shadow-sm h-100">
                                <h5 class="card-title text-success mb-3"><i class="bi bi-gear-fill me-2"></i>Acciones de Asignación</h5>

                                @using (Html.BeginForm("ProcesarAccionesInvestigadores", "Lider", FormMethod.Post, new { id = "formAccionesInvestigadores" }))
                                {
                                    <input type="hidden" id="hiddenSemilleroId" name="idSemilleroSeleccionado" value="@idSemilleroSeleccionadoSeccion4" />
                                    <input type="hidden" id="hiddenUsuarioId" name="idUsuarioSeleccionado" value="" />
                                    <input type="hidden" id="hiddenAccionInv" name="accionInvestigador" value="" />

                                    <div class="mb-4">
                                        <label class="form-label small fw-bold text-muted">Semillero a Consultar</label>
                                        <select id="comboSemilleroSeccion4" class="form-control-custom" onchange="cambiarSemilleroSeccion4(this.value)" style="border-color: #74c69d;">
                                            <option value="">Seleccione un semillero de origen...</option>
                                            @if (ViewBag.SemillerosFiltro != null)
                                            {
                                                foreach (var s in ViewBag.SemillerosFiltro as List<GestionSemillero1.Models.semillero>)
                                                {
                                                    <option value="@s.ID_semillero" @(idSemilleroSeleccionadoSeccion4 == s.ID_semillero ? "selected" : "")>@s.nombre_semillero</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="d-flex flex-column gap-2">
                                        <button type="button" onclick="ejecutarAccionInvestigador('habilitar')" class="btn btn-light text-start border-0 p-3" style="border-radius: 8px; font-weight: 500;"><i class="bi bi-person-check text-success me-3"></i>Habilitar Investigador</button>
                                        <button type="button" onclick="ejecutarAccionInvestigador('deshabilitar')" class="btn btn-light text-start border-0 p-3" style="border-radius: 8px; font-weight: 500;"><i class="bi bi-person-x text-warning me-3"></i>Deshabilitar Investigador</button>
                                        <button type="button" onclick="ejecutarAccionInvestigador('eliminar')" class="btn btn-outline-danger text-start p-3" style="border-radius: 8px; font-weight: 500;"><i class="bi bi-trash me-3"></i>Eliminar de este Semillero</button>

                                        <button type="button" id="btnAbrirModalAgregar" class="btn btn-success text-center mt-3 py-2 fw-bold" style="border-radius: 8px;"><i class="bi bi-person-plus-fill me-2"></i>Agregar Investigador</button>
                                    </div>
                                }

                                <div class="mt-4 p-3 bg-light rounded text-center text-muted small" style="border: 1px dashed #ced4da;">
                                    <span id="infoSeleccion" class="fw-bold">Ningún miembro seleccionado de la tabla</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-8 mb-4">
                            <div class="dashboard-card shadow-sm h-100">
                                <h5 class="card-title mb-4">
                                    <i class="bi bi-people-fill text-info me-2"></i>Miembros Vinculados: <span class="text-success">@ViewBag.NombreSemilleroSeleccionado4</span>
                                </h5>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle" id="tablaInvestigadores" style="cursor:pointer;">
                                        <thead class="table-light">
                                            <tr>
                                                <th>ID</th>
                                                <th>Nombre Completo</th>
                                                <th>Correo Institucional</th>
                                                <th>Estado Cuenta</th>
                                                <th style="display:none;">ID Usuario Oculto</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (ViewBag.InvestigadoresDeEsteSemillero != null && (ViewBag.InvestigadoresDeEsteSemillero as List<GestionSemillero1.Models.InvestigadorFiltroViewModel>).Any())
                                            {
                                                foreach (var inv in ViewBag.InvestigadoresDeEsteSemillero as List<GestionSemillero1.Models.InvestigadorFiltroViewModel>)
                                                {
                                                    <tr>
                                                        <td class="fw-bold">@inv.ID_investigador</td>
                                                        <td>@inv.NombreCompleto</td>
                                                        <td>@inv.correo_usuario</td>
                                                        <td><span class="badge @(inv.estado_usuario == "activo" || inv.estado_usuario == "Activo" ? "bg-success" : "bg-danger") text-white p-2" style="border-radius:6px;">@inv.estado_usuario</span></td>
                                                        <td style="display:none;" class="id-user-oculto">@inv.ID_usuario</td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr><td colspan="4" class="text-center text-muted p-5">Por favor seleccione un semillero en el cuadro de la izquierda para desplegar sus integrantes.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN DE RESULTADOS DE FILTROS -->
                @if (seccionActiva == "filtros")
                {
                    <div class="tab-pane fade show active">
                        <div class="dashboard-card shadow-sm">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="card-title m-0"><i class="bi bi-funnel text-primary me-2"></i>Resultados de la Búsqueda Avanzada</h5>
                                <a href="@Url.Action("GestionarSemillero", "Lider", new { seccionCargada = "semilleros" })" class="btn btn-sm btn-outline-secondary" style="border-radius:6px;">Restablecer Vista</a>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Semillero</th>
                                            <th>Línea de Investigación</th>
                                            <th>Fecha Creación</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (ViewBag.ResultadoFiltros != null && (ViewBag.ResultadoFiltros as List<GestionSemillero1.Models.semillero>).Any())
                                        {
                                            foreach (var item in ViewBag.ResultadoFiltros as List<GestionSemillero1.Models.semillero>)
                                            {
                                                <tr>
                                                    <td class="fw-bold">@item.nombre_semillero</td>
                                                    <td>@item.linea_investigacion</td>
                                                    <td>@item.fecha_creacion_semillero.ToString("yyyy-MM-dd")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="3" class="text-center text-muted p-4">Ningún semillero coincide con los filtros aplicados.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<!-- MODAL DE AGREGAR INVESTIGADOR -->
<div class="modal fade" id="modalAgregarInvestigador" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header">
                <h5 class="modal-title fw-bold text-primary"><i class="bi bi-person-plus-fill me-2"></i>Asignar Nuevo Investigador</h5>
                <button type="button" class="btn-close" id="btnCerrarModalX" aria-label="Close"></button>
            </div>
            @using (Html.BeginForm("ProcesarAccionesInvestigadores", "Lider", FormMethod.Post))
            {
                <div class="modal-body">
                    <input type="hidden" name="idSemilleroSeleccionado" value="@idSemilleroSeleccionadoSeccion4" />
                    <input type="hidden" name="accionInvestigador" value="agregar" />

                    <p class="small text-muted mb-3">Vinculando personal al grupo ID: <strong class="text-success">@idSemilleroSeleccionadoSeccion4</strong></p>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Correo Institucional</label>
                            <input type="email" name="nuevoInvestigadorCorreo" class="form-control-custom" placeholder="Ej: daniel@sena.edu.co" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Contraseña Inicial</label>
                            <input type="password" name="nuevoInvestigadorContrasena" class="form-control-custom" placeholder="Asigne clave" required />
                        </div>
                    </div>

                    <hr class="my-2" style="color: #dee2e6;" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Nombres</label>
                        <input type="text" name="nuevoInvestigadorNombre" class="form-control-custom" placeholder="Nombres completos" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Apellidos</label>
                        <input type="text" name="nuevoInvestigadorApellido" class="form-control-custom" placeholder="Apellidos completos" required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Tipo Doc.</label>
                            <select name="nuevoInvestigadorDoc" class="form-control-custom" required>
                                <option value="CC">C.C.</option>
                                <option value="TI">T.I.</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Edad</label>
                            <input type="number" name="nuevoInvestigadorEdad" class="form-control-custom" placeholder="Edad" min="15" max="90" required />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold">Teléfono Celular</label>
                        <input type="text" name="nuevoInvestigadorTel" class="form-control-custom" placeholder="Número de contacto" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" id="btnCerrarModalCancel">Cancelar</button>
                    <button type="submit" class="btn btn-success btn-sm fw-bold">Guardar Registro</button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function cambiarVistaPestaña(tipo) {
        if(tipo === 'semilleros') {
            window.location.href = `@Url.Action("GestionarSemillero", "Lider")?seccionCargada=semilleros`;
        } else if(tipo === 'investigadores') {
            window.location.href = `@Url.Action("GestionarSemillero", "Lider")?seccionCargada=investigadores`;
        }
    }

    function cambiarSemilleroSeccion4(idSemillero) {
        if(idSemillero) {
            window.location.href = `@Url.Action("GestionarSemillero", "Lider")?seccionCargada=investigadores&idSemilleroSeccion4=${idSemillero}`;
        } else {
            window.location.href = `@Url.Action("GestionarSemillero", "Lider")?seccionCargada=semilleros`;
        }
    }

    function ejecutarAccionInvestigador(accion) {
        const idUsuario = document.getElementById("hiddenUsuarioId").value;
        const idSemillero = document.getElementById("hiddenSemilleroId").value;

        if (idSemillero === "0" || idSemillero === "") {
            alert("Por favor seleccione un semillero en el combobox antes de procesar.");
            return;
        }
        if (!idUsuario) {
            alert("Por favor seleccione un investigador de la tabla haciendo clic sobre su fila.");
            return;
        }

        if (confirm(`¿Confirmar acción [${accion}] sobre el investigador seleccionado?`)) {
            document.getElementById("hiddenAccionInv").value = accion;
            document.getElementById("formAccionesInvestigadores").submit();
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const tablaSemilleros = document.getElementById("tablaSemilleros");
        const txtID = document.getElementById("txtID");
        const txtNombre = document.getElementById("txtNombre");
        const txtLinea = document.getElementById("txtLinea");
        const txtFecha = document.getElementById("txtFecha");
        const txtDescripcion = document.getElementById("txtDescripcion");
        const btnLimpiar = document.getElementById("btnLimpiar");
        const idAutoincrementableOriginal = "@ViewBag.SiguienteID";

        const tablaInvestigadores = document.getElementById("tablaInvestigadores");
        const infoSeleccion = document.getElementById("infoSeleccion");
        const hiddenUsuarioId = document.getElementById("hiddenUsuarioId");

        const btnAbrirModal = document.getElementById("btnAbrirModalAgregar");
        const modalElement = document.getElementById("modalAgregarInvestigador");
        const btnCerrarX = document.getElementById("btnCerrarModalX");
        const btnCerrarCancel = document.getElementById("btnCerrarModalCancel");

        if (btnAbrirModal) {
            btnAbrirModal.addEventListener("click", function () {
                const idSemillero = document.getElementById("hiddenSemilleroId").value;
                if (idSemillero === "0" || idSemillero === "") {
                    alert("Debe seleccionar un semillero en el combobox antes de poder añadirle investigadores.");
                    return;
                }
                modalElement.classList.add("show");
                modalElement.style.display = "block";
                document.body.classList.add("modal-open");
            });
        }

        function cerrarModal() {
            modalElement.classList.remove("show");
            modalElement.style.display = "none";
            document.body.classList.remove("modal-open");
        }
        if (btnCerrarX) btnCerrarX.addEventListener("click", cerrarModal);
        if (btnCerrarCancel) btnCerrarCancel.addEventListener("click", cerrarModal);

        // =========================================================================
        // MANEJO LOCAL DE SELECCIÓN DE FILAS DE SEMILLERO (CORREGIDO SIN SUBMIT)
        // =========================================================================
        if (tablaSemilleros) {
            tablaSemilleros.querySelectorAll("tbody tr").forEach(fila => {
                fila.addEventListener("click", function () {
                    if (this.querySelector(".ID-celda")) {
                        // Sombreado elegante de fila
                        tablaSemilleros.querySelectorAll("tbody tr").forEach(r => r.style.backgroundColor = "");
                        this.style.backgroundColor = "rgba(40, 167, 69, 0.08)";

                        // Llenado instantáneo en caliente de controles superiores
                        txtID.value = this.cells[0].innerText.trim();
                        txtNombre.value = this.cells[1].innerText.trim();
                        txtFecha.value = this.cells[2].innerText.trim();
                        txtLinea.value = this.cells[3].innerText.trim();
                        txtDescripcion.value = this.querySelector(".descripcion-oculta").innerText.trim();
                    }
                });
            });
        }

        if (btnLimpiar) {
            btnLimpiar.addEventListener("click", function () {
                if(tablaSemilleros) {
                    tablaSemilleros.querySelectorAll("tbody tr").forEach(r => r.style.backgroundColor = "");
                }
                txtID.value = idAutoincrementableOriginal;
                txtNombre.value = "";
                txtLinea.value = "";
                txtFecha.value = "";
                txtDescripcion.value = "";
            });
        }

        if (tablaInvestigadores) {
            tablaInvestigadores.querySelectorAll("tbody tr").forEach(fila => {
                fila.addEventListener("click", function () {
                    if (this.querySelector(".id-user-oculto")) {
                        tablaInvestigadores.querySelectorAll("tbody tr").forEach(r => r.style.backgroundColor = "");

                        this.style.backgroundColor = "rgba(116, 198, 157, 0.15)";
                        const idUser = this.querySelector(".id-user-oculto").innerText.trim();
                        const nombreCompleto = this.cells[1].innerText.trim();

                        hiddenUsuarioId.value = idUser;
                        infoSeleccion.innerHTML = `<strong>Seleccionado:</strong> ${nombreCompleto}`;
                        infoSeleccion.style.color = "#2d6a4f";
                    }
                });
            });
        }
    });
</script>