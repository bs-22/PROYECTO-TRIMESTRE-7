@model IEnumerable<GestionSemillero1.Models.semillero>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Gestión de Semillero";

    // 1. Extraemos los datos del semillero (asumiendo que el líder solo administra uno)
    var miSemillero = Model != null ? Model.FirstOrDefault() : null;
    string idSem = miSemillero != null ? miSemillero.ID_semillero.ToString() : "";
    string nomSem = miSemillero != null ? miSemillero.nombre_semillero : "";
    string linSem = miSemillero != null ? miSemillero.linea_investigacion : "";
    string fecSem = miSemillero != null ? miSemillero.fecha_creacion_semillero.ToString("yyyy-MM-dd") : "";
    string desSem = miSemillero != null ? miSemillero.descripcion_semillero : "";
    string estSem = miSemillero != null ? miSemillero.estado : "Inactivo";

    // 2. Extraemos la lista de investigadores enviada desde el controlador
    var investigadores = ViewBag.InvestigadoresDeEsteSemillero as List<GestionSemillero1.Models.InvestigadorFiltroViewModel> ?? new List<GestionSemillero1.Models.InvestigadorFiltroViewModel>();
}

<style>
    .btn-action-custom {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        padding: 10px 15px;
        border-radius: 8px;
        font-weight: 600;
        text-align: center;
        transition: all 0.3s ease;
    }

    .table-header-banner {
        padding: 15px;
        font-weight: 600;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        border-radius: .5rem .5rem 0 0;
    }

    .form-control-custom {
        border-radius: 6px;
        border: 1px solid #ced4da;
        padding: 0.5rem 0.75rem;
        width: 100%;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .form-control-custom:focus {
            border-color: #278a5f;
            outline: 0;
            box-shadow: 0 0 0 0.2rem rgba(39, 138, 95, 0.25);
        }

    .step-badge {
        display: inline-block;
        width: 24px;
        height: 24px;
        text-align: center;
        line-height: 24px;
        border-radius: 50%;
        font-size: 0.85rem;
        margin-right: 8px;
    }

    .badge-estado {
        padding: 5px 10px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .badge-activo {
        background-color: #278a5f;
        color: white;
    }

    .badge-inactivo {
        background-color: #d42346;
        color: white;
    }

    .mini-table-card {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 20px;
    }
</style>

<div class="container-fluid p-4">

    <div class="mb-4 mt-2">
        <h3 class="fw-bold text-dark">
            <i class="bi bi-people-fill me-2" style="color: #278a5f;"></i>Módulo de Gestión de Semilleros
        </h3>
        <p class="text-muted small">Administre la información central de su semillero y gestione a los investigadores vinculados.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="border-radius: 8px;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="border-radius: 8px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-5">
        <div class="col-xl-8 col-lg-7 mb-4 mb-lg-0">
            <div class="card shadow-sm p-4 bg-white" style="border-radius: 12px; height: 100%; border: none;">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-3">
                    <i class="bi bi-pencil-square me-2" style="color:#278a5f;"></i>Actualizar Información del Semillero
                </h5>

                <form action="@Url.Action("GestionarSemillero", "Lider")" method="POST">
                    <input type="hidden" name="accion" value="actualizar" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted"><span class="step-badge text-white" style="background-color: #278a5f;">1</span> Identificación</label>
                            <input type="text" name="ID_semillero" class="form-control-custom mb-2 text-muted" value="@idSem" readonly style="background-color:#f8f9fa; cursor: not-allowed;" />
                            <input type="text" name="nombre_semillero" class="form-control-custom" value="@nomSem" placeholder="Nombre del semillero" maxlength="45" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted"><span class="step-badge text-white" style="background-color: #278a5f;">2</span> Clasificación</label>
                            <input type="text" name="linea_investigacion" class="form-control-custom mb-2" value="@linSem" placeholder="Línea de investigación" maxlength="40" required />
                            <input type="date" name="fecha_creacion_semillero" class="form-control-custom text-muted" value="@fecSem" readonly style="background-color:#f8f9fa; cursor: not-allowed;" required />
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label small fw-bold text-muted"><span class="step-badge text-white" style="background-color: #278a5f;">3</span> Descripción General</label>
                            <textarea name="descripcion_semillero" class="form-control-custom" rows="3" maxlength="255" required>@desSem</textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-start mt-3 gap-2">
                        <button type="submit" class="btn text-white px-5 fw-bold" style="background-color: #c98d26; border-radius: 8px;">
                            <i class="bi bi-arrow-clockwise me-2"></i>Actualizar Semillero
                        </button>
                        <a href="@Url.Action("GestionarSemillero", "Lider")" class="btn btn-secondary px-4 fw-bold text-decoration-none" style="border-radius: 8px;">
                            <i class="bi bi-x-circle me-2"></i>Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5 mb-4 mb-lg-0">
            <div class="mini-table-card shadow-sm h-100 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <div class="d-inline-block p-3 rounded-circle mb-3" style="background-color: #e9f2ee;">
                        <i class="bi bi-diagram-3-fill fs-1" style="color: #278a5f;"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Resumen Actual</h5>
                    @if (estSem.ToLower() == "activo")
                    {
                        <span class="badge badge-activo px-3">Estado: ACTIVO</span>
                    }
                    else
                    {
                        <span class="badge badge-inactivo px-3">Estado: INACTIVO</span>
                    }
                </div>

                <table class="table table-sm table-borderless mt-2">
                    <tbody>
                        <tr>
                            <td class="text-muted fw-bold small" style="width: 40%;">ID Semillero:</td>
                            <td class="text-dark fw-semibold text-end">#@idSem</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold small">Nombre:</td>
                            <td class="text-dark fw-semibold text-end">@nomSem</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold small">Línea Enfoque:</td>
                            <td class="text-dark fw-semibold text-end">@linSem</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold small">Fecha Creación:</td>
                            <td class="text-dark fw-semibold text-end">@fecSem</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm bg-white" style="border-radius: 12px; padding: 0; border: none; overflow: hidden;">
        <div class="table-header-banner text-white justify-content-between" style="background: linear-gradient(87deg, #278a5f 0, #278a5f 100%);">
            <div>
                <i class="bi bi-people-fill text-white me-2"></i>Miembros Vinculados: @(string.IsNullOrEmpty(nomSem) ? "Semillero Actual" : nomSem)
            </div>
            <button type="button" id="btnAbrirModalAgregar" class="btn btn-sm btn-light fw-bold shadow-sm" style="color: #278a5f; border-radius: 6px;">
                <i class="bi bi-person-plus-fill me-1"></i> Agregar Investigador
            </button>
        </div>

        <div class="table-responsive p-3 border-bottom">
            <table class="table table-hover align-middle mb-0 text-center" id="tablaInvestigadores" style="cursor:pointer;">
                <thead class="table-light">
                    <tr>
                        <th>ID Usuario</th>
                        <th>Nombre Completo</th>
                        <th>Correo Institucional</th>
                        <th>Estado Cuenta</th>
                        <th>Info</th>
                        <th style="display:none;">ID Usuario Oculto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.InvestigadoresDeEsteSemillero != null && ((System.Collections.IEnumerable)ViewBag.InvestigadoresDeEsteSemillero).GetEnumerator().MoveNext())
                    {
                        foreach (dynamic inv in ViewBag.InvestigadoresDeEsteSemillero)
                        {
                            string estadoInv = inv.estado_usuario != null ? inv.estado_usuario.ToString().ToLower() : "";

                            <tr onclick="seleccionarInvestigador(this, '@inv.ID_usuario', '@inv.NombreCompleto')">
                                <td class="fw-bold text-dark">@inv.ID_investigador</td>
                                <td style="color: #32325d; font-weight: 600;">@inv.NombreCompleto</td>
                                <td class="text-muted">@inv.correo_usuario</td>
                                <td>
                                    @if (estadoInv == "activo" || estadoInv == "activa")
                                    {
                                        <span class="badge text-white px-3 py-1" style="background-color: #278a5f; border-radius:6px;">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger text-white px-3 py-1" style="border-radius:6px;">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" class="btn btn-link p-0 text-decoration-none" style="color: #278a5f;"
                                            onclick="verInfoInvestigador(event, this)"
                                            data-id="@inv.ID_investigador"
                                            data-idusuario="@inv.ID_usuario"
                                            data-nombre="@inv.NombreCompleto"
                                            data-correo="@inv.correo_usuario"
                                            data-estado="@estadoInv">
                                        <i class="bi bi-info-circle-fill fs-5" title="Ver perfil del investigador"></i>
                                    </button>
                                </td>
                                <td style="display:none;" class="id-user-oculto">@inv.ID_usuario</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted p-5 font-italic">
                                <i class="bi bi-person-x fs-2 d-block mb-2"></i>Actualmente no hay investigadores registrados en este semillero.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-light p-3 d-flex flex-wrap justify-content-between align-items-center">
            <div class="text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                <span id="infoSeleccion" class="fw-bold">Ningún investigador seleccionado en la tabla</span>
            </div>
            <div class="d-flex gap-2">
                <button type="button" onclick="ejecutarAccionInvestigador('habilitar')" class="btn btn-outline-success fw-bold bg-white disabled" id="btnHabilitar" style="border-radius: 8px;">
                    <i class="bi bi-person-check me-1"></i> Habilitar
                </button>
                <button type="button" onclick="ejecutarAccionInvestigador('deshabilitar')" class="btn btn-outline-warning text-dark fw-bold bg-white disabled" id="btnDeshabilitar" style="border-radius: 8px;">
                    <i class="bi bi-person-x me-1"></i> Deshabilitar
                </button>
                <button type="button" onclick="ejecutarAccionInvestigador('eliminar')" class="btn btn-outline-danger fw-bold bg-white disabled" id="btnEliminarUsr" style="border-radius: 8px;">
                    <i class="bi bi-trash me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

<form id="formAccionesFila" action="@Url.Action("ProcesarAccionesInvestigadores", "Lider")" method="post" style="display:none;">
    <input type="hidden" id="hiddenFilaSemilleroId" name="idSemilleroSeleccionado" value="@idSem" />
    <input type="hidden" id="hiddenFilaUsuarioId" name="idUsuarioSeleccionado" value="" />
    <input type="hidden" id="hiddenFilaAccion" name="accionInvestigador" value="" />
</form>

<div class="modal fade" id="modalInfoInvestigador" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
            <div class="modal-header text-white" style="background-color: #278a5f; border-top-left-radius: 15px; border-top-right-radius: 15px;">
                <h6 class="modal-title fw-bold"><i class="bi bi-person-vcard me-2"></i>Ficha del Investigador</h6>
                <button type="button" class="border-0 bg-transparent fs-5 text-white text-decoration-none" onclick="cerrarModalInfo()" style="outline: none;">&times;</button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="display-1 text-muted mb-3">
                    <i class="bi bi-person-circle"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1" id="modInvNombre">Nombre Apellido</h5>
                <p class="text-muted small mb-3" id="modInvCorreo">correo@sena.edu.co</p>

                <div class="d-flex justify-content-between border-top border-bottom py-2 mb-3">
                    <div class="text-center w-50 border-end">
                        <small class="text-muted d-block fw-bold" style="font-size:0.7rem;">ID USUARIO</small>
                        <strong class="text-dark fs-5" id="modInvIdUsuario">0000</strong>
                    </div>
                    <div class="text-center w-50">
                        <small class="text-muted d-block fw-bold" style="font-size:0.7rem;">ESTADO</small>
                        <span id="modInvEstado" class="badge bg-success mt-1 px-3">Activo</span>
                    </div>
                </div>

                <button type="button" class="btn btn-secondary btn-sm w-100 fw-bold" onclick="cerrarModalInfo()">Cerrar Perfil</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAgregarInvestigador" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px; overflow: hidden; border: none;">
            <div class="modal-header text-white" style="background-color: #278a5f;">
                <h5 class="modal-title fw-bold text-white"><i class="bi bi-person-plus-fill me-2"></i>Asignar Nuevo Investigador</h5>
                <button type="button" class="btn-close btn-close-white" id="btnCerrarModalX" aria-label="Close"></button>
            </div>
            @using (Html.BeginForm("ProcesarAccionesInvestigadores", "Lider", FormMethod.Post))
            {
                <div class="modal-body p-4">
                    <input type="hidden" name="idSemilleroSeleccionado" value="@idSem" />
                    <input type="hidden" name="accionInvestigador" value="agregar" />

                    <p class="small text-muted mb-3">Vinculando personal al grupo ID: <strong style="color: #278a5f;">@idSem</strong></p>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Correo Institucional</label>
                            <input type="email" name="nuevoInvestigadorCorreo" class="form-control-custom" placeholder="Ej: daniel@sena.edu.co" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Contraseña Inicial</label>
                            <input type="password" name="nuevoInvestigadorContrasena" class="form-control-custom" placeholder="Asigne clave" required />
                        </div>
                    </div>

                    <hr class="my-2" style="color: #dee2e6;" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Nombres</label>
                        <input type="text" name="nuevoInvestigadorNombre" class="form-control-custom" placeholder="Nombres completos" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Apellidos</label>
                        <input type="text" name="nuevoInvestigadorApellido" class="form-control-custom" placeholder="Apellidos completos" required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Tipo Doc.</label>
                            <select name="nuevoInvestigadorDoc" class="form-control-custom" required>
                                <option value="CC">C.C.</option>
                                <option value="TI">T.I.</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Edad</label>
                            <input type="number" name="nuevoInvestigadorEdad" class="form-control-custom" placeholder="Edad" min="15" max="90" required />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold">Teléfono Celular</label>
                        <input type="text" name="nuevoInvestigadorTel" class="form-control-custom" placeholder="Número de contacto" required />
                    </div>
                </div>
                <div class="modal-footer bg-light p-3 border-0">
                    <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" id="btnCerrarModalCancel" style="border-radius: 6px;">Cancelar</button>
                    <button type="submit" class="btn text-white btn-sm fw-bold px-4" style="background-color: #278a5f; border-radius: 6px;">Guardar Registro</button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script>
        // --- LÓGICA DE SELECCIÓN DE FILAS EN LA TABLA ---
        function seleccionarInvestigador(fila, idUsuario, nombreCompleto) {
            const filas = document.querySelectorAll("#tablaInvestigadores tbody tr");
            filas.forEach(f => f.style.backgroundColor = "transparent");

            fila.style.backgroundColor = "rgba(39, 138, 95, 0.12)";

            document.getElementById("hiddenFilaUsuarioId").value = idUsuario;
            document.getElementById("infoSeleccion").innerHTML = `Seleccionado: <span style="color: #278a5f;">${nombreCompleto}</span>`;

            document.getElementById("btnHabilitar").classList.remove("disabled");
            document.getElementById("btnDeshabilitar").classList.remove("disabled");
            document.getElementById("btnEliminarUsr").classList.remove("disabled");
        }

        // --- LÓGICA DE BOTONES INFERIORES ---
        function ejecutarAccionInvestigador(accion) {
            const idUsuario = document.getElementById("hiddenFilaUsuarioId").value;
            const idSemillero = document.getElementById("hiddenFilaSemilleroId").value;

            if (!idSemillero || idSemillero === "0") {
                alert("No se ha identificado el semillero. Actualice la página e intente de nuevo.");
                return;
            }

            if (!idUsuario) {
                alert("Por favor seleccione un investigador en la tabla antes de continuar.");
                return;
            }

            let msjAccion = accion === 'eliminar' ? 'eliminar permanentemente a' : accion;

            if (confirm(`¿Está seguro de que desea ${msjAccion} este investigador?`)) {
                document.getElementById("hiddenFilaAccion").value = accion;
                document.getElementById("formAccionesFila").submit();
            }
        }

        // --- LÓGICA DEL MODAL DE INFORMACIÓN (EL ÍCONO "!") ---
        function verInfoInvestigador(e, btn) {
            e.stopPropagation();

            const data = btn.dataset;
            document.getElementById("modInvNombre").innerText = data.nombre;
            document.getElementById("modInvCorreo").innerText = data.correo;
            document.getElementById("modInvIdUsuario").innerText = data.idusuario;

            const badge = document.getElementById("modInvEstado");
            if (data.estado === "activo" || data.estado === "activa") {
                badge.className = "badge bg-success mt-1 px-3";
                badge.innerText = "Activo";
            } else {
                badge.className = "badge bg-danger mt-1 px-3";
                badge.innerText = "Inactivo";
            }

            const modal = document.getElementById("modalInfoInvestigador");
            modal.style.display = "block";
            modal.style.backgroundColor = "rgba(0,0,0,0.5)";
            setTimeout(() => { modal.classList.add("show"); }, 10);
            document.body.style.overflow = "hidden";
        }

        function cerrarModalInfo() {
            const modal = document.getElementById("modalInfoInvestigador");
            modal.classList.remove("show");
            setTimeout(() => { modal.style.display = "none"; document.body.style.overflow = "auto"; }, 200);
        }

        // --- LÓGICA DEL MODAL PARA AGREGAR INVESTIGADOR ---
        document.addEventListener("DOMContentLoaded", function () {
            const btnAbrirModal = document.getElementById("btnAbrirModalAgregar");
            const modalElement = document.getElementById("modalAgregarInvestigador");
            const btnCerrarX = document.getElementById("btnCerrarModalX");
            const btnCerrarCancel = document.getElementById("btnCerrarModalCancel");

            if (btnAbrirModal) {
                btnAbrirModal.addEventListener("click", function () {
                    modalElement.classList.add("show");
                    modalElement.style.display = "block";
                    modalElement.style.backgroundColor = "rgba(0,0,0,0.5)";
                    document.body.style.overflow = "hidden";
                });
            }

            function cerrarModalAdd() {
                modalElement.classList.remove("show");
                setTimeout(() => {
                    modalElement.style.display = "none";
                    document.body.style.overflow = "auto";
                }, 200);
            }

            if (btnCerrarX) btnCerrarX.addEventListener("click", cerrarModalAdd);
            if (btnCerrarCancel) btnCerrarCancel.addEventListener("click", cerrarModalAdd);
        });
    </script>
}