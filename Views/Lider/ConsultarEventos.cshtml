@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Consultar Eventos";
    string criterio = ViewBag.CriterioActual ?? "";
    string valor = ViewBag.ValorActual ?? "";
}

<style>
    /* Ajustes específicos para los botones de acción para mantener simetría */
    .btn-action-custom {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        padding: 10px 15px;
        border-radius: 8px;
        font-weight: 600;
        text-align: center;
        transition: all 0.3s ease;
    }

    .btn-search-custom {
        background-color: #278a5f;
        color: white;
        border: none;
    }

        .btn-search-custom:hover {
            background-color: #1e6d4a;
            color: white;
            box-shadow: 0 4px 6px rgba(39, 138, 95, 0.3);
        }

    .btn-clear-custom {
        background-color: transparent;
        color: #6c757d;
        border: 1px solid #6c757d;
    }

        .btn-clear-custom:hover {
            background-color: #f8f9fa;
            color: #343a40;
        }
</style>

<div class="container-fluid">

    <!-- 🌟 NUEVO ENCABEZADO SUPERIOR 🌟 -->
    <div class="mb-4 mt-2">
        <h3 class="fw-bold text-dark">
            <i class="bi bi-calendar2-event me-2" style="color: #278a5f;"></i>Módulo de Consulta de Eventos
        </h3>
        <p class="text-muted small">Realice búsquedas específicas y visualice el cronograma institucional de ponencias y ferias.</p>
    </div>

    <div class="row">
        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="dashboard-card" style="height: auto;">
                <div class="card-title text-dark">
                    <i class="bi bi-search me-2" style="color: #278a5f;"></i>Búsqueda de Eventos
                </div>

                @using (Html.BeginForm("ConsultarEventos", "Lider", FormMethod.Get))
                {
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Por favor seleccione alguna de las siguientes opciones</label>
                        <select name="criterioFiltro" id="criterioFiltro" class="form-control-custom" required>
                            <option value="">Seleccione filtro...</option>
                            <option value="nombre" @(criterio == "nombre" ? "selected" : "")>Nombre del Evento</option>
                            <option value="semillero" @(criterio == "semillero" ? "selected" : "")>Nombre del Semillero</option>
                            <option value="fecha" @(criterio == "fecha" ? "selected" : "")>Fecha Específica</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Ahora ingrese la información que quiere buscar relacionado con la opción escogida</label>
                        <input type="text" name="valorBusqueda" id="valorBusqueda" class="form-control-custom" value="@valor" placeholder="Escriba aquí su búsqueda..." list="sugerenciasDinamicas" required autocomplete="off" />
                        <datalist id="sugerenciasDinamicas"></datalist>
                    </div>

                    <!-- Botones de Acción Simétricos -->
                    <div class="mb-3 d-flex flex-column gap-2">
                        <button type="submit" class="btn-action-custom btn-search-custom">
                            <i class="bi bi-filter me-2"></i>Buscar con filtro
                        </button>

                        <a href="@Url.Action("ConsultarEventos", "Lider")" class="btn-action-custom btn-clear-custom text-decoration-none">
                            <i class="bi bi-x-circle me-2"></i> Limpiar filtros
                        </a>
                    </div>
                }

                <!-- Mensaje de fecha (Oculto por defecto con d-none) -->
                <div id="mensajeRecomendacionFecha" class="mt-4 p-3 bg-light rounded d-none" style="border: 1px dashed #cad1d7;">
                    <p class="small text-muted m-0 text-center fw-bold">
                        <i class="bi bi-info-circle text-warning me-2"></i>Recomendación: Si es por fecha, siga la estructura año-mes-día (AAAA-MM-DD)
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="table-responsive-container" style="margin-top: 0;">
                <!-- Banner Verde Institucional -->
                <div class="table-header-banner text-white" style="background: linear-gradient(87deg, #278a5f 0, #278a5f 100%);">
                    <i class="bi bi-calendar-event-fill me-2"></i>Cronograma institucional de Eventos y Ponencias
                </div>

                <table class="custom-table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre Evento</th>
                            <th>Descripción</th>
                            <th>Fecha</th>
                            <th>Semillero Asociado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.EventosResultado != null && ((System.Collections.IEnumerable)ViewBag.EventosResultado).GetEnumerator().MoveNext())
                        {
                            foreach (dynamic ev in ViewBag.EventosResultado)
                            {
                                <tr>
                                    <td class="fw-bold">@ev.ID_evento</td>
                                    <td style="color: #32325d; font-weight: 600;">@ev.nombre_evento</td>
                                    <td>@ev.descripción_evento</td>

                                    <!-- 🌟 AQUÍ SE QUITÓ EL COLOR VERDE DE LA FECHA 🌟 -->
                                    <td class="text-dark fw-semibold">
                                        @(ev.fecha_evento != null ? ev.fecha_evento.ToString("dd/MM/yyyy") : "")
                                    </td>

                                    <td class="fw-bold" style="color: #278a5f;">@ev.nombre_semillero</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted p-5">
                                    <i class="bi bi-calendar-x me-2" style="font-size: 1.5rem;"></i><br />
                                    No se encontraron eventos registrados que coincidan con el criterio.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- 🌟 SCRIPT QUE SE ENCARGA DEL AUTOCOMPLETADO INTELIGENTE (TOP 5) Y LÓGICA VISUAL -->
@section scripts {
    <script>
        const datosGlobalesEventos = [
            @if(ViewBag.EventosResultado != null) {
                foreach(dynamic ev in ViewBag.EventosResultado) {
                    <text>{ nombre: '@ev.nombre_evento', semillero: '@ev.nombre_semillero', fecha: '@(ev.fecha_evento != null ? ev.fecha_evento.ToString("yyyy-MM-dd") : "")' },</text>
                }
            }
        ];

        document.addEventListener("DOMContentLoaded", function () {
            const selectFiltro = document.getElementById("criterioFiltro");
            const datalist = document.getElementById("sugerenciasDinamicas");
            const msjFecha = document.getElementById("mensajeRecomendacionFecha"); // Referencia al div del mensaje

            function actualizarSugerencias() {
                if(!selectFiltro || !datalist) return;

                const filtroActivo = selectFiltro.value.toLowerCase();

                // LÓGICA VISUAL: Mostrar u ocultar el mensaje de recomendación de fecha
                if (filtroActivo === "fecha") {
                    msjFecha.classList.remove("d-none"); // Lo muestra
                } else {
                    msjFecha.classList.add("d-none"); // Lo oculta
                }

                datalist.innerHTML = ""; // Limpiamos las opciones viejas
                let opcionesBrutas = [];

                if (filtroActivo === "nombre") {
                    opcionesBrutas = datosGlobalesEventos.map(e => e.nombre);
                } else if (filtroActivo === "semillero") {
                    opcionesBrutas = datosGlobalesEventos.map(e => e.semillero);
                } else if (filtroActivo === "fecha") {
                    opcionesBrutas = datosGlobalesEventos.map(e => e.fecha);
                }

                const opcionesValidas = opcionesBrutas.filter(op => op && op.trim() !== "");
                const top5Sugerencias = [...new Set(opcionesValidas)].slice(0, 5);

                top5Sugerencias.forEach(op => {
                    let optionElement = document.createElement("option");
                    optionElement.value = op;
                    datalist.appendChild(optionElement);
                });
            }

            if(selectFiltro) {
                selectFiltro.addEventListener("change", actualizarSugerencias);
                actualizarSugerencias(); // Disparamos la función al iniciar
            }
        });
    </script>
}