@using GestionSemillero1.Models
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Investigador</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Content/dashboard.css" rel="stylesheet" />

    <style>
        .sidebar {
            background-color: #ffffff !important;
            color: #333333 !important;
            border-right: 1px solid #eaeaea;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
        }

            .sidebar .profile-card h6,
            .sidebar .profile-card small,
            .sidebar .profile-avatar i {
                color: #333333 !important;
            }

            .sidebar .nav-link, .btn-logout {
                color: #333333 !important;
                text-decoration: none !important;
                padding: 12px 15px;
                font-weight: 500;
            }

                .sidebar .nav-link span, .btn-logout span {
                    text-decoration: underline;
                    text-decoration-color: #a8e6cf !important;
                    text-decoration-thickness: 3px;
                    text-underline-offset: 4px;
                    transition: text-decoration-color 0.3s ease;
                }

                .sidebar .nav-link:hover span, .btn-logout:hover span {
                    text-decoration-color: #74c69d !important;
                }

            .sidebar i {
                margin-right: 8px;
                color: #555;
            }

        /* Botón header reuniones */
        .btn-reuniones-header {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
            border: none;
            border-radius: 25px;
            padding: 10px 28px;
            font-weight: 600;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            margin-bottom: 24px;
        }

        /* Tabla */
        .tabla-reuniones thead {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
        }

            .tabla-reuniones thead th {
                padding: 12px 16px;
                font-weight: 600;
                border: none;
                text-align: center;
                color: white !important;
            }

        .tabla-reuniones tbody td {
            padding: 12px 16px;
            text-align: center;
            vertical-align: middle;
            border-bottom: 1px solid #f0f0f0;
        }

        .tabla-reuniones tbody tr:hover {
            background-color: #f6fff9;
        }

        /* Modal filtros */
        .modal-header-custom {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
            border-radius: 12px 12px 0 0;
            padding: 16px 24px;
        }

            .modal-header-custom .btn-close {
                filter: brightness(0) invert(1);
            }

        .modal-content {
            border-radius: 12px;
            border: none;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        }

        .filtro-label {
            font-weight: 500;
            color: #555;
            margin-bottom: 6px;
            font-size: 0.9rem;
        }

        .form-select-custom, .form-input-custom {
            border: 1.5px solid #d0d0d0;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 0.9rem;
            width: 100%;
            outline: none;
            transition: border-color 0.2s;
        }

            .form-select-custom:focus, .form-input-custom:focus {
                border-color: #2ecc71;
            }

        .btn-buscar {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            font-weight: 600;
            cursor: pointer;
        }

            .btn-buscar:hover {
                background: linear-gradient(135deg, #27ae60, #1e8449);
            }
    </style>
</head>
<body>

    <div class="sidebar">
        <div>
            <div class="profile-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="profile-avatar">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">@Session["UsuarioLogueado"]</h6>
                        <small class="opacity-75">Rol Investigador</small>
                    </div>
                </div>
            </div>

            <nav class="d-flex flex-column mt-4">
                <a class="nav-link active" href="@Url.Action("Index", "Investigador")">
                    <i class="bi bi-camera-video"></i> <span>Consultar Reuniones</span>
                </a>
            </nav>
        </div>

        <div class="logout-container">
            <a class="btn-logout" href="@Url.Action("Logout", "Account")">
                <i class="bi bi-box-arrow-left"></i> <span>Cerrar sesión</span>
            </a>
        </div>
    </div>

    <div class="main-content">

        <div class="d-flex align-items-center justify-content-between mb-2">
            <button class="btn-reuniones-header" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                <i class="bi bi-arrow-right-circle-fill"></i> Próximas reuniones
            </button>
        </div>

        <div class="dashboard-card p-0 overflow-hidden">
            <table class="table tabla-reuniones mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Descripción</th>
                        <th>ID Semillero</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Reuniones != null && ((List<Reunion>)ViewBag.Reuniones).Any())
                    {
                        foreach (var r in (List<Reunion>)ViewBag.Reuniones)
                        {
                            <tr>
                                <td>@r.ID_reunion</td>
                                <td>@r.fecha_reunion.ToString("dd/MM/yyyy")</td>
                                <td>@r.hora_reunion</td>
                                <td>@r.descripcion_reunion</td>
                                <td>@r.ID_semillero</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No hay reuniones próximas registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header-custom d-flex align-items-center justify-content-between">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-arrow-right-circle-fill me-2"></i> Consultar por filtros
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form method="GET" action="@Url.Action("Index", "Investigador")">
                        <p class="filtro-label">Por favor seleccione la opción que desea filtrar</p>
                        <div class="d-flex gap-3 mb-4">
                            <select name="criterioFiltro" class="form-select-custom" style="max-width:200px">
                                <option value="">-- Seleccione --</option>
                                <option value="ID" @(ViewBag.CriterioActual == "ID" ? "selected" : "")>ID</option>
                                <option value="Mes" @(ViewBag.CriterioActual == "Mes" ? "selected" : "")>Mes</option>
                                <option value="Fecha" @(ViewBag.CriterioActual == "Fecha" ? "selected" : "")>Fecha</option>
                            </select>
                            <input type="text" name="valorBusqueda" class="form-input-custom"
                                   value="@ViewBag.ValorActual" placeholder="Ingrese valor..." />
                            <button type="submit" class="btn-buscar">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table tabla-reuniones mb-0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Fecha</th>
                                    <th>Hora</th>
                                    <th>Descripción</th>
                                    <th>ID Semillero</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.Reuniones != null && ((List<Reunion>)ViewBag.Reuniones).Any())
                                {
                                    foreach (var r in (List<Reunion>)ViewBag.Reuniones)
                                    {
                                        <tr>
                                            <td>@r.ID_reunion</td>
                                            <td>@r.fecha_reunion.ToString("dd/MM/yyyy")</td>
                                            <td>@r.hora_reunion</td>
                                            <td>@r.descripcion_reunion</td>
                                            <td>@r.ID_semillero</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">Sin resultados.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Si hay filtro activo, reabrir el modal automáticamente
        window.addEventListener('load', function () {
            var criterio = '@ViewBag.CriterioActual';
            if (criterio && criterio !== '') {
                var modal = new bootstrap.Modal(document.getElementById('modalFiltros'));
                modal.show();
            }
        });
    </script>
</body>
</html>