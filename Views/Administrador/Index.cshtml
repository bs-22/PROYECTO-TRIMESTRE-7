@model List<GestionSemillero1.Models.semillero>
@{
    ViewBag.Title = "Menú Principal";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";

    var comboSemilleros = ViewBag.ListaSemilleros as List<GestionSemillero1.Models.semillero>;
    var comboLineas = ViewBag.ListaLineas as List<string>;
    var todosSemilleros = ViewBag.TodosSemilleros as List<GestionSemillero1.Models.semillero>;
}

<style>
    .filter-card {
        background: #ffffff;
        border: none;
        border-radius: 12px;
    }

    .dashboard-card {
        background: #ffffff;
        border: none;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .semillero-badge-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none !important;
        border-radius: 10px;
    }

    .card-semillero-click:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.08) !important;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

    .sticky-table-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: #f8fafc !important;
    }
</style>

<div class="container-fluid px-2" style="font-size: 0.9rem;">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="card filter-card shadow-sm p-4 bg-white">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-2 bg-success-subtle text-success rounded-3 me-2"><i class="bi bi-funnel-fill fs-5"></i></div>
                    <h5 class="fw-bold text-dark m-0" style="font-size: 1.1rem;">Búsqueda y Filtros</h5>
                </div>
                @using (Html.BeginForm("Index", "Administrador", FormMethod.Get, new { id = "formFiltrosUnificado" }))
                {
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary"><i class="bi bi-tree me-1"></i> Por nombre</label>
                        <select name="filtroSemillero" class="form-select form-select-sm">
                            <option value="">-- Ver todos --</option>
                            @foreach (var sem in comboSemilleros ?? new List<GestionSemillero1.Models.semillero>())
                            {
                                <option value="@sem.ID_semillero" @(ViewBag.SemilleroSeleccionado?.ToString() == sem.ID_semillero.ToString() ? "selected" : "")>@sem.nombre_semillero</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary"><i class="bi bi-tags me-1"></i> Línea</label>
                        <select name="filtroLinea" class="form-select form-select-sm">
                            <option value="">-- Ver todas --</option>
                            @foreach (var linea in comboLineas ?? new List<string>())
                            {
                                <option value="@linea" @(ViewBag.LineaSeleccionada?.ToString() == linea ? "selected" : "")>@linea</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-sm btn-success w-100 fw-bold"><i class="bi bi-search me-1"></i> Aplicar</button>
                }
            </div>
        </div>

        <div class="col-md-9">
            <div class="card dashboard-card shadow-sm mb-4 p-4 bg-white">
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-bold text-dark fs-5">Semilleros Institucionales</span>
                </div>
                <div class="row custom-scrollbar" style="max-height: 310px; overflow-y: auto;">
                    @foreach (var item in Model ?? new List<GestionSemillero1.Models.semillero>())
                    {
                        <div class="col-xl-6 col-md-12 mb-3">
                            <div class="card h-100 shadow-sm border-start border-4 border-success semillero-badge-card bg-light card-semillero-click" data-id="@item.ID_semillero">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold text-primary">@item.nombre_semillero</h6>
                                    <p class="small text-muted">@item.descripcion_semillero</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card dashboard-card shadow-sm p-4 bg-white">
                <div class="fw-bold text-dark mb-3" id="txtTituloFormulario">Registrar Semillero</div>
                @using (Html.BeginForm("GuardarSemillero", "Administrador", FormMethod.Post, new { id = "formGestionSemillero" }))
                {
                    <input type="hidden" id="hdnIDSemillero" name="ID_semillero" value="0" />
                    <input type="hidden" id="hdnAccion" name="accion" value="agregar" />

                    <div class="row g-3">
                        <div class="col-md-6"><input type="text" class="form-control form-control-sm" id="txtNombreSemillero" name="nombre_semillero" required placeholder="Nombre" /></div>
                        <div class="col-md-6"><input type="text" class="form-control form-control-sm" id="txtLineaInvestigacion" name="linea_investigacion" required placeholder="Línea" /></div>
                        <div class="col-md-12"><textarea class="form-control form-control-sm" name="descripcion_semillero" id="txtDescripcionSemillero" placeholder="Descripción"></textarea></div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" onclick="$('#hdnAccion').val('actualizar')" class="btn btn-warning btn-sm d-none" id="btnActualizarSem">Actualizar</button>
                        <button type="submit" onclick="$('#hdnAccion').val('agregar')" class="btn btn-success btn-sm" id="btnAgregarSem">Registrar</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(".fila-semillero").click(function () {
            var c = $(this).find("td");
            $("#hdnIDSemillero").val(c.eq(0).text().trim());
            $("#txtNombreSemillero").val(c.eq(1).text().trim());
            $("#txtLineaInvestigacion").val($(this).data("linea"));
            $("#txtDescripcionSemillero").val($(this).data("desc"));

            $("#btnAgregarSem").addClass("d-none");
            $("#btnActualizarSem").removeClass("d-none");
        });
    </script>
}