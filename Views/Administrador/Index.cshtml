@model List<GestionSemillero1.Models.semillero>
@{
    ViewBag.Title = "Menú Principal - Administrador";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";
}

<style>
    :root {
        --sena-green: #39a900;
    }

    .card-sena {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background-color: #ffffff;
    }

    .card-sena-header {
        border-left: 5px solid var(--sena-green);
    }

    .btn-sena {
        background-color: var(--sena-green);
        color: white;
        border: none;
        text-decoration: none;
    }

        .btn-sena:hover {
            background-color: #2e8b00;
            color: white;
            text-decoration: none;
        }

    .bg-sena {
        background-color: var(--sena-green);
        color: white;
    }

    /* Clases para Validaciones y Limpieza Visual */
    a {
        text-decoration: none !important;
    }

    .error-border {
        border: 2px solid #dc3545 !important;
    }

    .msg-error {
        color: #dc3545;
        font-size: 0.75rem;
        display: none;
        margin-top: 4px;
        font-weight: bold;
    }

    /* Scroll personalizado para la vista rápida */
    .scroll-container {
        max-height: 400px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    /* Estilos del Encabezado de Sección */
    .header-icon-box {
        background-color: #d1e7dd; /* Verde sutil institucional */
        color: #198754;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }
</style>

<div class="container-fluid px-2" style="font-size: 0.9rem;">

    <div class="d-flex align-items-center mb-4 mt-2">
        <div class="header-icon-box me-3 shadow-sm">
            <i class="bi bi-tree-fill fs-3"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-1" style="color: #2c3e50;">Módulo de Gestión de Semilleros</h4>
            <p class="text-muted mb-0">Administre los grupos de investigación, asigne líneas de enfoque y supervise su estado operativo en el sistema.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card p-3 shadow-sm card-sena">
                <h6 class="fw-bold text-success"><i class="bi bi-funnel-fill"></i> Busqueda por filtro</h6>
                @using (Html.BeginForm("Index", "Administrador", FormMethod.Get, new { id = "formFiltros" }))
                {
                    <label class="small mt-2 fw-bold">Seleccione un semillero</label>
                    <select name="filtroSemillero" id="fSemillero" class="form-select mb-2">
                        <option value="">-- Seleccione --</option>
                        @foreach (var s in ViewBag.ListaSemilleros)
                        {
                            <option value="@s.ID_semillero">@s.nombre_semillero</option>
                        }
                    </select>
                    <button type="button" class="btn btn-secondary btn-sm w-100 mb-3" onclick="validarFiltro('fSemillero')">Buscar</button>

                    <label class="small fw-bold">Línea de investigación</label>
                    <select name="filtroLinea" id="fLinea" class="form-select mb-2">
                        <option value="">-- Seleccione --</option>
                        @foreach (var l in ViewBag.ListaLineas)
                        {
                            <option value="@l">@l</option>
                        }
                    </select>
                    <button type="button" class="btn btn-secondary btn-sm w-100 mb-3" onclick="validarFiltro('fLinea')">Buscar</button>

                    <label class="small fw-bold">Consultar por fecha</label>
                    <input type="date" name="filtroFecha" id="fFecha" class="form-control mb-2" />
                    <button type="button" class="btn btn-secondary btn-sm w-100 mb-2" onclick="validarFiltro('fFecha')">Consultar</button>

                    <div class="text-center mt-2">
                        <a href="@Url.Action("Index")" class="btn btn-link btn-sm text-dark"><i class="bi bi-arrow-clockwise"></i> Restablecer vista</a>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-9">
            <div class="card p-4 shadow-sm card-sena h-100">
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                    <h6 class="fw-bold m-0"><i class="bi bi-tree-fill text-success"></i> Vista Rápida de Semilleros</h6>
                    <span class="badge bg-success">@Model.Count(s => s.estado == "activo") activos</span>
                </div>

                <div class="row scroll-container pe-2">
                    @foreach (var s in Model)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card p-3 card-sena-header shadow-sm h-100">
                                <h6 class="fw-bold text-primary">@s.nombre_semillero</h6>
                                <p class="small text-muted mb-1">Código ID: @s.ID_semillero</p>
                                <p class="small">@s.descripcion_semillero</p>
                                <div class="d-flex justify-content-between small text-muted mt-auto">
                                    <span><i class="bi bi-tag"></i> @s.linea_investigacion</span>
                                    <span><i class="bi bi-calendar"></i> @s.fecha_creacion_semillero.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-7">
            <div class="card p-4 shadow-sm card-sena h-100">
                <h6 class="fw-bold mb-3"><i class="bi bi-table text-success"></i> Historial y Registros</h6>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-sm m-0">
                        <thead class="table-light"><tr><th>ID</th><th>Semillero</th><th>Estado</th></tr></thead>
                        <tbody>
                            @foreach (var s in (List<GestionSemillero1.Models.semillero>)ViewBag.TodosSemilleros)
                            {
                                // Lógica extraída del controlador para identificar al líder actual de esta fila
                                var lideresActuales = ViewBag.LideresActuales as IEnumerable<dynamic>;
                                string idLiderAsignado = "";

                                if (lideresActuales != null)
                                {
                                    foreach (var liderAct in lideresActuales)
                                    {
                                        if (liderAct.ID_semillero == s.ID_semillero)
                                        {
                                            idLiderAsignado = liderAct.ID_usuario.ToString();
                                            break;
                                        }
                                    }
                                }

                                <tr style="cursor:pointer;" onclick="cargarFormulario(@s.ID_semillero, '@s.nombre_semillero', '@s.linea_investigacion', '@s.descripcion_semillero', '@idLiderAsignado')">
                                    <td>@s.ID_semillero</td>
                                    <td>@s.nombre_semillero</td>
                                    <td class="text-center"><span class="badge @(s.estado == "activo" ? "bg-success" : "bg-danger")">@s.estado</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card p-4 shadow-sm bg-light card-sena h-100">
                <h6 class="fw-bold mb-3"><i class="bi bi-pencil-square text-success"></i> Acciones y Detalles</h6>
                @using (Html.BeginForm("GuardarSemillero", "Administrador", FormMethod.Post, new { id = "formSemillero" }))
                {
                    <input type="hidden" name="ID_semillero" id="hdnID" value="0" />

                    <div class="mb-2 position-relative">
                        <label class="small fw-bold text-secondary">Nombre</label>
                        <input type="text" name="nombre_semillero" id="txtNombre" class="form-control form-control-sm" required />
                    </div>

                    <div class="mb-2 position-relative">
                        <label class="small fw-bold text-secondary">Línea de investigación</label>
                        <input type="text" name="linea_investigacion" id="txtLinea" class="form-control form-control-sm" required />
                    </div>

                    <div class="mb-2 position-relative">
                        <label class="small fw-bold text-secondary">Líder asignado</label>
                        <select name="idLiderSeleccionado" id="ddlLider" class="form-select form-select-sm">
                            <option value="">-- Mantener actual / Seleccione para cambiar --</option>
                            @foreach (dynamic l in ViewBag.ComboLideres)
                            {
                                // Utilizamos dynamic y try-catch oculto mediante propiedades para evitar errores si usas DTO o modelo Usuario
                                string idValor = l.GetType().GetProperty("ID_usuario") != null ? l.ID_usuario.ToString() : "";
                                string nombreMostrado = l.GetType().GetProperty("NombreCompleto") != null ? l.NombreCompleto : l.correo_usuario;

                                <option value="@idValor" data-nombre="@nombreMostrado">@nombreMostrado</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="small fw-bold text-secondary">ID asignado</label>
                        <input type="text" id="txtIdVisual" class="form-control form-control-sm text-muted bg-light" readonly placeholder="Generado automáticamente" />
                    </div>

                    <div class="mb-3 position-relative">
                        <label class="small fw-bold text-secondary">Descripción general</label>
                        <textarea name="descripcion_semillero" id="txtDesc" class="form-control form-control-sm" rows="3" required></textarea>
                    </div>

                    <div class="d-flex flex-wrap gap-2 justify-content-end mt-auto">
                        <button type="button" class="btn btn-secondary btn-sm shadow-sm" onclick="limpiarFormulario()">Cancelar</button>
                        <button type="button" class="btn btn-outline-danger btn-sm shadow-sm" onclick="validarAccionEspecifica('Desactivar')">Desactivar</button>
                        <button type="button" class="btn btn-outline-success btn-sm shadow-sm" onclick="validarAccionEspecifica('Activar')">Activar</button>
                        <button type="submit" class="btn btn-sena btn-sm shadow-sm">Guardar / Actualizar</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // --- 1. Lógica del Formulario de Acciones ---
    function cargarFormulario(id, nombre, linea, desc, idLiderActual) {
        $("#hdnID").val(id);
        $("#txtIdVisual").val(id);
        $("#txtNombre").val(nombre);
        $("#txtLinea").val(linea);
        $("#txtDesc").val(desc);

        // LÓGICA MÁGICA DEL LÍDER
        let selectLider = $("#ddlLider");

        // 1. Restaurar el select limpiando bloqueos anteriores
        selectLider.find("option").each(function () {
            $(this).prop("disabled", false);
            let nombreOriginal = $(this).attr("data-nombre");
            if (nombreOriginal) {
                $(this).text(nombreOriginal);
            }
        });

        // 2. Si el semillero ya tiene un líder en la base de datos...
        if (idLiderActual && idLiderActual !== "") {
            selectLider.val(idLiderActual); // Seleccionamos la opción

            let opcionActual = selectLider.find("option:selected");
            if (opcionActual.length > 0) {
                // Le agregamos el aviso visual y lo bloqueamos
                opcionActual.text(opcionActual.attr("data-nombre") + " (Líder Actual)");
                opcionActual.prop("disabled", true);
            }
        } else {
            selectLider.val(""); // Lo dejamos en la primera opción por defecto
        }

        $("#formSemillero").find('.error-border').removeClass('error-border');
        $(".msg-error").hide();

        // Desplazamiento suave si el usuario hace click en la tabla inferior
        $('html, body').animate({ scrollTop: $("#txtIdVisual").offset().top - 150 }, 150);
    }

    function limpiarFormulario() {
        $("#formSemillero")[0].reset();
        $("#hdnID").val("0");
        $("#txtIdVisual").val("");

        // Restaurar el select de líderes a su estado limpio para registrar nuevos
        let selectLider = $("#ddlLider");
        selectLider.find("option").each(function () {
            $(this).prop("disabled", false);
            let nombreOriginal = $(this).attr("data-nombre");
            if (nombreOriginal) {
                $(this).text(nombreOriginal);
            }
        });
        selectLider.val("");

        $("#formSemillero").find('.error-border').removeClass('error-border');
        $(".msg-error").hide();
    }

    // --- 2. Validación "On-Blur" ---
    document.querySelectorAll('#formSemillero input[required], #formSemillero select[required], #formSemillero textarea[required]').forEach(input => {
        input.addEventListener('blur', function () {
            if (this.value.trim() === '') {
                this.classList.add('error-border');
                if (!this.nextElementSibling || !this.nextElementSibling.classList.contains('msg-error')) {
                    let msg = document.createElement('div');
                    msg.className = 'msg-error';
                    msg.innerText = 'Este campo es obligatorio.';
                    this.parentNode.appendChild(msg);
                }
                this.nextElementSibling.style.display = 'block';
            } else {
                this.classList.remove('error-border');
                if (this.nextElementSibling && this.nextElementSibling.classList.contains('msg-error')) {
                    this.nextElementSibling.style.display = 'none';
                }
            }
        });
    });

    // --- 3. Validación "On-Submit" ---
    $("#formSemillero").submit(function (e) {
        let valid = true;
        $(this).find('input[required], select[required], textarea[required]').each(function () {
            if ($(this).val().trim() === "") {
                $(this).addClass('error-border');
                if (!this.nextElementSibling || !this.nextElementSibling.classList.contains('msg-error')) {
                    let msg = document.createElement('div');
                    msg.className = 'msg-error';
                    msg.innerText = 'Este campo es obligatorio.';
                    this.parentNode.appendChild(msg);
                }
                this.nextElementSibling.style.display = 'block';
                valid = false;
            } else {
                $(this).removeClass('error-border');
            }
        });

        if (!valid) {
            e.preventDefault();
            alert("Acción denegada: Debes rellenar todos los campos obligatorios antes de guardar.");
        }
    });

    // --- 4. Validación para Botones de Acción ---
    function validarAccionEspecifica(accion) {
        if ($("#hdnID").val() == "0") {
            alert("Denegado: No puedes " + accion.toLowerCase() + ". Primero debes seleccionar un semillero de la tabla de historial.");
        } else {
            if (confirm("¿Estás seguro de que deseas " + accion.toLowerCase() + " este semillero?")) {
                alert("Acción confirmada (Simulación). Conecta el backend aquí.");
            }
        }
    }

    // --- 5. Validación Filtros ---
    function validarFiltro(idCampo) {
        let campo = document.getElementById(idCampo);
        if (campo.value.trim() === '') {
            alert("Por favor, seleccione o ingrese un valor válido para filtrar.");
            campo.focus();
        } else {
            document.getElementById('formFiltros').submit();
        }
    }
</script>