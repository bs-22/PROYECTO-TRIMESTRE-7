@model List<GestionSemillero1.Models.semillero>
@{
    ViewBag.Title = "Menú Principal";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";

    var comboSemilleros = ViewBag.ListaSemilleros as List<GestionSemillero1.Models.semillero>;
    var comboLineas = ViewBag.ListaLineas as List<string>;
    var todosSemilleros = ViewBag.TodosSemilleros as List<GestionSemillero1.Models.semillero>;
}

<style>
    /* Estilos de modernización UI/UX */
    .filter-card {
        background: #ffffff;
        border: none;
        border-radius: 12px;
    }

    .dashboard-card {
        background: #ffffff;
        border: none;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .semillero-badge-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none !important;
        border-radius: 10px;
    }

    .card-semillero-click:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.08) !important;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

    .sticky-table-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: #f8fafc !important;
    }
</style>

<div class="container-fluid px-2" style="font-size: 0.9rem;">
    <div class="row g-4">

        <div class="col-md-3">
            <div class="card filter-card shadow-sm p-4 bg-white">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-2 bg-success-subtle text-success rounded-3 me-2">
                        <i class="bi bi-funnel-fill fs-5"></i>
                    </div>
                    <h5 class="fw-bold text-dark m-0" style="font-size: 1.1rem;">Búsqueda y Filtros</h5>
                </div>

                <p class="text-muted small mb-4">Diligencie uno o más criterios para segmentar la vista del panel principal.</p>

                @using (Html.BeginForm("Index", "Administrador", FormMethod.Get, new { id = "formFiltrosUnificado" }))
                {
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary"><i class="bi bi-tree me-1"></i> Por nombre de semillero</label>
                        <select name="filtroSemillero" class="form-select form-select-sm">
                            <option value="">-- Ver todos los semilleros --</option>
                            @if (comboSemilleros != null)
                            {
                                foreach (var sem in comboSemilleros)
                                {
                                    <option value="@sem.ID_semillero" @(ViewBag.SemilleroSeleccionado?.ToString() == sem.ID_semillero.ToString() ? "selected" : "")>@sem.nombre_semillero</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary"><i class="bi bi-tags me-1"></i> Línea de investigación</label>
                        <select name="filtroLinea" class="form-select form-select-sm">
                            <option value="">-- Ver todas las líneas --</option>
                            @if (comboLineas != null)
                            {
                                foreach (var linea in comboLineas)
                                {
                                    <option value="@linea" @(ViewBag.LineaSeleccionada?.ToString() == linea ? "selected" : "")>@linea</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary"><i class="bi bi-calendar-event me-1"></i> Apertura por fecha</label>
                        <input type="date" name="filtroFecha" class="form-control form-control-sm" value="@ViewBag.FechaSeleccionada" />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-sm btn-success fw-bold py-2 shadow-sm"><i class="bi bi-search me-1"></i> Aplicar Criterios</button>
                        <a href="@Url.Action("Index", "Administrador")" class="btn btn-sm btn-outline-secondary py-2 text-decoration-none text-center"><i class="bi bi-arrow-counterclockwise"></i> Restablecer panel</a>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-9">

            <div class="card dashboard-card shadow-sm mb-4 p-4 bg-white">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-grid-1x2-fill text-primary fs-5 me-2"></i>
                        <span class="fw-bold text-dark fs-5">Vista Rápida de Semilleros Institucionales</span>
                    </div>
                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 fw-bold" style="font-size: 0.85rem;">@Model.Count Proyectos Activos</span>
                </div>

                <div class="row custom-scrollbar" style="max-height: 310px; overflow-y: auto; padding-right: 4px;">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="col-xl-6 col-md-12 mb-3">
                                <div class="card h-100 shadow-sm border-start border-4 border-success semillero-badge-card card-semillero-click bg-light" data-id="@item.ID_semillero">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h6 class="card-title fw-bold text-primary mb-1 text-truncate" style="font-size: 1rem; max-width: 80%;">@item.nombre_semillero</h6>
                                            <span class="text-muted font-monospace small" style="font-size: 0.75rem;">#@item.ID_semillero</span>
                                        </div>
                                        <p class="card-text text-secondary mb-3 small text-wrap text-truncate" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; height: 36px;">@item.descripcion_semillero</p>

                                        <div class="d-flex justify-content-between align-items-center border-top pt-2">
                                            <span class="badge bg-white text-secondary border px-2 py-1 text-truncate" style="font-size: 0.75rem; max-width: 65%;"><i class="bi bi-bookmark-fill me-1 text-success"></i>@item.linea_investigacion</span>
                                            <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>@item.fecha_creacion_semillero.ToString("dd/MM/yyyy")</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center text-muted my-4">
                            <i class="bi bi-folder-x fs-2 text-secondary"></i>
                            <p class="mt-2 m-0 small fw-semibold">No se encontraron semilleros activos bajo los parámetros de búsqueda.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="row g-3">

                <div class="col-lg-5 col-md-12">
                    <div class="card dashboard-card shadow-sm p-4 bg-white h-100">
                        <div class="box-title mb-3 fw-bold text-dark fs-6"><i class="bi bi-journal-bookmark text-secondary me-2"></i>Historial General</div>
                        <div class="table-responsive rounded border custom-scrollbar" style="max-height: 380px; overflow-y: auto;">
                            <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                                <thead class="table-light sticky-top sticky-table-header">
                                    <tr>
                                        <th>ID</th>
                                        <th>Semillero</th>
                                        <th class="text-center">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (todosSemilleros != null)
                                    {
                                        foreach (var sem in todosSemilleros)
                                        {
                                            <tr style="cursor: pointer;" class="fila-semillero" data-linea="@sem.linea_investigacion" data-desc="@sem.descripcion_semillero" data-estado="@sem.estado">
                                                <td class="fw-bold text-primary id-sem-celda">@sem.ID_semillero</td>
                                                <td class="text-dark fw-semibold text-truncate" style="max-width: 140px;">@sem.nombre_semillero</td>
                                                <td class="text-center">
                                                    @if (sem.estado.ToLower() == "activo")
                                                    {
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill">Activo</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-pill">Inactivo</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 col-md-12">
                    <div class="card dashboard-card shadow-sm p-4 bg-white h-100">
                        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                            <div class="box-title fw-bold text-dark fs-6" id="txtTituloFormulario"><i class="bi bi-plus-circle-fill text-success me-2"></i>Registrar Nuevo Semillero</div>
                            <button type="button" class="btn btn-sm btn-link text-muted text-decoration-none d-none" id="btnResetForm" onclick="resetearFormularioModoAgregar()"><i class="bi bi-arrow-left-short"></i> Volver a nuevo</button>
                        </div>

                        @using (Html.BeginForm("GuardarSemillero", "Administrador", FormMethod.Post, new { id = "formGestionSemillero" }))
                        {
                            <input type="hidden" id="hdnIDSemillero" name="ID_semillero" value="0" />

                            <div class="row g-3" style="font-size: 0.85rem;">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary mb-1">Nombre del Semillero</label>
                                    <input type="text" class="form-control form-control-sm" id="txtNombreSemillero" name="nombre_semillero" required placeholder="Ej: Semillero de Software" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary mb-1">Línea de Investigación</label>
                                    <input type="text" class="form-control form-control-sm" id="txtLineaInvestigacion" name="linea_investigacion" required placeholder="Ej: Desarrollo Web" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary mb-1">Líder Investigador Asignado</label>
                                    <select class="form-select form-select-sm" id="ddlLiderSemillero">
                                        <option value="">-- Asignar Líder... --</option>
                                        @foreach (var lider in ViewBag.ComboLideres as List<GestionSemillero1.Models.Usuario>)
                                        {
                                            <option value="@lider.ID_usuario">@lider.correo_usuario</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary mb-1">ID del Sistema</label>
                                    <input type="text" class="form-control form-control-sm bg-light text-muted fw-bold" id="txtIDVisual" readonly placeholder="Mapeo Automático" />
                                </div>
                            </div>

                            <div class="mt-3">
                                <label class="form-label fw-bold text-secondary mb-1">Descripción y Enfoque General</label>
                                <textarea class="form-control form-control-sm" id="txtDescripcionSemillero" name="descripcion_semillero" rows="3" required placeholder="Escriba el alcance, metas y justificación del semillero de investigación..."></textarea>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                                <button type="button" class="btn btn-outline-danger btn-sm fw-bold px-3 d-none" id="btnDesactivarSem"><i class="bi bi-lock-fill me-1"></i> Deshabilitar</button>
                                <button type="button" class="btn btn-outline-success btn-sm fw-bold px-3 d-none" id="btnActivarSem"><i class="bi bi-unlock-fill me-1"></i> Habilitar</button>
                                <button type="submit" class="btn btn-warning text-dark btn-sm fw-bold px-4 shadow-sm d-none" id="btnActualizarSem"><i class="bi bi-pencil-square me-1"></i> Actualizar Datos</button>
                                <button type="submit" class="btn btn-success btn-sm fw-bold px-4 shadow-sm" id="btnAgregarSem"><i class="bi bi-check-lg me-1"></i> Registrar Semillero</button>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Evento clic en las filas del Historial
            $(".fila-semillero").click(function () {
                $(".fila-semillero").removeClass("table-success text-success table-active");
                $(this).addClass("table-success-subtle table-active");

                var c = $(this).find("td");
                var id = c.eq(0).text().trim();
                var nombre = c.eq(1).text().trim();

                // DATA ATRIBUTES (Mapeo seguro y libre de bugs de índices)
                var linea = $(this).data("linea");
                var desc = $(this).data("desc");
                var estado = $(this).data("estado").toString().toLowerCase();

                // Cargar los controles del formulario
                $("#hdnIDSemillero").val(id);
                $("#txtIDVisual").val(id);
                $("#txtNombreSemillero").val(nombre);
                $("#txtLineaInvestigacion").val(linea);
                $("#txtDescripcionSemillero").val(desc);

                // ACTIVACIÓN DE MODO EDICIÓN (Cambio de títulos y botones)
                $("#txtTituloFormulario").html('<i class="bi bi-pencil-square text-warning me-2"></i>Modificar Semillero Seleccionado');
                $("#btnResetForm").removeClass("d-none");
                $("#btnAgregarSem").addClass("d-none");
                $("#btnActualizarSem").removeClass("d-none");

                if (estado === "activo") {
                    $("#btnDesactivarSem").removeClass("d-none");
                    $("#btnActivarSem").addClass("d-none");
                } else {
                    $("#btnActivarSem").removeClass("d-none");
                    $("#btnDesactivarSem").addClass("d-none");
                }
            });

            // Enlace entre tarjetas de vista rápida e historial
            $(".card-semillero-click").click(function () {
                var targetId = $(this).data("id");
                $(".fila-semillero").each(function () {
                    if ($(this).find(".id-sem-celda").text().trim() == targetId) {
                        $(this).click();
                        // Scroll automático para enfocar el formulario
                        $('html, body').animate({ scrollTop: $("#formGestionSemillero").offset().top - 100 }, 200);
                    }
                });
            });
        });

        // Función para restaurar el formulario al modo "Agregar"
        function resetearFormularioModoAgregar() {
            $("#hdnIDSemillero").val("0");
            $("#txtIDVisual").val("");
            $("#formGestionSemillero")[0].reset();

            $("#txtTituloFormulario").html('<i class="bi bi-plus-circle-fill text-success me-2"></i>Registrar Nuevo Semillero');
            $("#btnResetForm").addClass("d-none");
            $("#btnAgregarSem").removeClass("d-none");

            $("#btnActualizarSem").addClass("d-none");
            $("#btnActivarSem").addClass("d-none");
            $("#btnDesactivarSem").addClass("d-none");
            $(".fila-semillero").removeClass("table-success-subtle table-active");
        }
    </script>
}